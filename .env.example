# === eBay Browse API (OAuth2 Client Credentials) ===
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_DE
EBAY_API_DELAY_MS=1100

# === Keepa API ===
KEEPA_API_KEY=

# === Supabase ===
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# === Worker-Tuning ===
# Keepa-Mindestpreis USED in EUR für neue ASINs
MIN_AMZ_USED_PRICE=25.00
# Wie viele NEUE ASINs pro Worker-Lauf maximal von Keepa holen (Obergrenze für Schritt 1)
MAX_SYNC_LIMIT=500
# Sicherheitslimit fuer Keepa-Details pro Lauf. 10000 ASINs dauern bei
# 20 Keepa-Tokens/min mehrere Stunden.
KEEPA_MAX_ASINS_PER_RUN=1000
# /product Batch-Groesse. Maximal 100; 20 passt gut zu kleinen Keepa-Konten.
KEEPA_PRODUCT_BATCH_SIZE=20

# === Frontend Basic Auth (optional) ===
# Wenn BOOKSCOUT_PASSWORD gesetzt ist, verlangt das Frontend Basic Auth.
# Standardbenutzer ist "admin", kann aber überschrieben werden.
BOOKSCOUT_USER=admin
BOOKSCOUT_PASSWORD=
